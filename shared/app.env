# Shared runtime configuration (dev/demo values — do not use in production).
JWT_SECRET=myownx-dev-secret-change-me-0123456789abcdef
JWT_TTL_SECONDS=86400

USER_SERVICE_URL=http://user-service:9001
POST_SERVICE_URL=http://post-service:9002

USER_DATABASE_URL=postgresql+asyncpg://user_service:user_service_pw@postgres:5432/users_db
POST_DATABASE_URL=postgresql+asyncpg://post_service:post_service_pw@postgres:5432/posts_db
